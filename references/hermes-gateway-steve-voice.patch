+    async def _enrich_message_with_voice_pipeline(
+        self,
+        user_text: str,
+        audio_paths: List[str],
+        source,
+    ) -> str:
+        project_root = resolve_steve_thought_capture_root(self.config, source)
+        if not project_root:
+            return await self._enrich_message_with_transcription(user_text, audio_paths)
+
+        enriched_parts = []
+        for path in audio_paths:
+            try:
+                logger.debug("Running Steve voice pipeline for %s", path)
+                result = await asyncio.to_thread(
+                    execute_steve_thought_capture_pipeline,
+                    path,
+                    source,
+                    project_root,
+                )
+                enriched_parts.append(format_steve_thought_capture_result(result))
+            except Exception as exc:
+                logger.warning(
+                    "Steve voice pipeline failed for %s, falling back to generic STT: %s",
+                    path,
+                    exc,
+                    exc_info=True,
+                )
+                return await self._enrich_message_with_transcription(user_text, audio_paths)
+
+        if enriched_parts:
+            prefix = "\n\n".join(enriched_parts)
+            _placeholder = "(The user sent a message with no text content)"
+            if user_text and user_text.strip() == _placeholder:
+                return prefix
+            if user_text:
+                return f"{prefix}\n\n{user_text}"
+            return prefix
+        return await self._enrich_message_with_transcription(user_text, audio_paths)
