+def build_steve_thought_capture_gateway_outcome(result: dict, user_text: str = "") -> dict[str, str]:
+    payload = _jsonable(result)
+    status = str(payload.get("status") or "unknown")
+    user_text = (user_text or "").strip()
+
+    if status == "ok":
+        normalized = payload.get("normalized_transcript") or {}
+        intent = payload.get("intent_decision") or {}
+        actions = _extract_action_types(payload.get("actions") or [])
+        normalized_text = str(normalized.get("normalized_text") or "").strip()
+        primary_intent = str(intent.get("primary_intent") or "").strip()
+        action_text = ", ".join(actions) if actions else "none"
+
+        if "reply" in actions and normalized_text:
+            text = normalized_text
+            if user_text:
+                text = f"{text}\n\n{user_text}"
+            return {"kind": "agent", "text": text}
+
+        instruction_parts = [
+            "[The user sent a voice message. Steve voice pipeline classified it before agent handling.",
+            f'Normalized transcript: "{normalized_text}".' if normalized_text else "Normalized transcript: \"\".",
+            f"Primary intent: {primary_intent or 'unknown'}.",
+            f"Planned actions: {action_text}.",
+            "Handle this request according to the planned action and reply to the user with the result.]",
+        ]
+        text = " ".join(part for part in instruction_parts if part)
+        if user_text:
+            text = f"{text}\n\n{user_text}"
+        return {"kind": "agent", "text": text}
+
+    if status == "needs_clarification":
+        question = str(payload.get("clarification_question") or "請再說清楚一點，我才能幫你處理。").strip()
+        return {"kind": "reply", "text": question}
+
+    if status == "asr_failed":
+        return {
+            "kind": "reply",
+            "text": "我收到你的語音了，但這次沒能成功轉成文字。請再說一次，或直接打字給我。",
+        }
+
+    return {
+        "kind": "reply",
+        "text": f"我收到你的語音了，但這次的處理狀態是 {status}。請再試一次，或直接打字給我。",
+    }
+
+
 def format_steve_thought_capture_result(result: dict) -> str:
     payload = _jsonable(result)
     status = str(payload.get("status") or "unknown")
