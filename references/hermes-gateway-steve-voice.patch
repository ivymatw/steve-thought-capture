diff --git a/gateway/steve_voice.py b/gateway/steve_voice.py
new file mode 100644
index 00000000..e8ff68d4
--- /dev/null
+++ b/gateway/steve_voice.py
@@ -0,0 +1,128 @@
+from __future__ import annotations
+
+import importlib
+import mimetypes
+import os
+import sys
+from dataclasses import asdict, is_dataclass
+from pathlib import Path
+from typing import Any, Iterable
+
+from gateway.config import Platform
+
+
+def _normalize_project_root(path: str | os.PathLike[str] | None) -> Path | None:
+    if not path:
+        return None
+    root = Path(path).expanduser().resolve()
+    if not (root / "src").exists():
+        return None
+    return root
+
+
+def resolve_steve_thought_capture_root(config, source) -> Path | None:
+    if getattr(source, "platform", None) != Platform.TELEGRAM:
+        return None
+
+    env_root = _normalize_project_root(os.getenv("HERMES_STEVE_THOUGHT_CAPTURE_ROOT"))
+    if not env_root:
+        telegram_cfg = (getattr(config, "platforms", {}) or {}).get(Platform.TELEGRAM)
+        extra = getattr(telegram_cfg, "extra", {}) if telegram_cfg else {}
+        env_root = _normalize_project_root(extra.get("steve_thought_capture_root"))
+    if not env_root:
+        return None
+
+    allowed_chat_ids = os.getenv("HERMES_STEVE_THOUGHT_CAPTURE_CHAT_IDS") or os.getenv("HERMES_STEVE_THOUGHT_CAPTURE_CHAT_ID")
+    if allowed_chat_ids:
+        allowed = {item.strip() for item in allowed_chat_ids.split(",") if item.strip()}
+        if allowed and str(getattr(source, "chat_id", "")) not in allowed:
+            return None
+    return env_root
+
+
+def _mime_type_for_audio(audio_path: str | os.PathLike[str]) -> str:
+    guessed = mimetypes.guess_type(str(audio_path))[0]
+    return guessed or "application/octet-stream"
+
+
+def execute_steve_thought_capture_pipeline(audio_path: str, source, project_root: Path) -> dict:
+    src_dir = project_root / "src"
+    if not src_dir.exists():
+        raise FileNotFoundError(f"steve-thought-capture src directory not found under {project_root}")
+    if str(src_dir) not in sys.path:
+        sys.path.insert(0, str(src_dir))
+
+    importlib.invalidate_caches()
+    models = importlib.import_module("steve_thought_capture.models")
+    pipeline = importlib.import_module("steve_thought_capture.pipeline")
+    steve_context = importlib.import_module("steve_thought_capture.steve_context")
+
+    voice_event = models.VoiceEvent(
+        platform="telegram",
+        chat_id=str(getattr(source, "chat_id", "")),
+        thread_id=getattr(source, "thread_id", None),
+        user_id=str(getattr(source, "user_id", "") or ""),
+        message_id=Path(audio_path).stem,
+        audio_path=str(Path(audio_path).expanduser().resolve()),
+        mime_type=_mime_type_for_audio(audio_path),
+        duration_seconds=None,
+        received_at=None,
+    )
+    context = steve_context.load_steve_context(project_root)
+    return pipeline.process_voice_event(voice_event, context)
+
+
+def _jsonable(value: Any) -> Any:
+    if is_dataclass(value):
+        return {k: _jsonable(v) for k, v in asdict(value).items()}
+    if isinstance(value, dict):
+        return {k: _jsonable(v) for k, v in value.items()}
+    if isinstance(value, (list, tuple)):
+        return [_jsonable(v) for v in value]
+    return value
+
+
+def _extract_action_types(actions: Iterable[Any]) -> list[str]:
+    action_types: list[str] = []
+    for action in actions or []:
+        action_json = _jsonable(action)
+        if isinstance(action_json, dict):
+            action_type = str(action_json.get("action_type") or action_json.get("action") or "").strip()
+            if action_type:
+                action_types.append(action_type)
+    return action_types
+
+
+def format_steve_thought_capture_result(result: dict) -> str:
+    payload = _jsonable(result)
+    status = str(payload.get("status") or "unknown")
+
+    if status == "ok":
+        normalized = payload.get("normalized_transcript") or {}
+        intent = payload.get("intent_decision") or {}
+        actions = _extract_action_types(payload.get("actions") or [])
+        normalized_text = str(normalized.get("normalized_text") or "").strip()
+        primary_intent = str(intent.get("primary_intent") or "").strip()
+        action_text = ", ".join(actions) if actions else "none"
+        return (
+            "[The user sent a voice message. Steve voice pipeline output: "
+            f'Normalized transcript: "{normalized_text}". '
+            f"Primary intent: {primary_intent or 'unknown'}. "
+            f"Planned actions: {action_text}.]"
+        )
+
+    if status == "needs_clarification":
+        question = str(payload.get("clarification_question") or "Please clarify.").strip()
+        return (
+            "[The user sent a voice message. Steve voice pipeline needs clarification "
+            f"before actioning it: {question}]"
+        )
+
+    if status == "asr_failed":
+        error = str(payload.get("error") or "unknown error").strip()
+        return (
+            "[The user sent a voice message. Steve voice pipeline could not transcribe it: "
+            f"{error}]"
+        )
+
+    return f"[The user sent a voice message. Steve voice pipeline returned status: {status}]"
diff --git a/tests/gateway/test_steve_voice_pipeline.py b/tests/gateway/test_steve_voice_pipeline.py
new file mode 100644
index 00000000..ed1a111a
--- /dev/null
+++ b/tests/gateway/test_steve_voice_pipeline.py
@@ -0,0 +1,69 @@
+from unittest.mock import patch
+
+import pytest
+
+from gateway.config import GatewayConfig, Platform
+from gateway.platforms.base import MessageEvent, MessageType
+from gateway.session import SessionSource
+
+
+@pytest.mark.asyncio
+async def test_prepare_inbound_message_text_uses_steve_voice_pipeline_when_configured(monkeypatch, tmp_path):
+    from gateway.run import GatewayRunner
+
+    runner = GatewayRunner.__new__(GatewayRunner)
+    runner.config = GatewayConfig(stt_enabled=True)
+    runner.adapters = {}
+    runner._model = "test-model"
+    runner._base_url = ""
+    runner._has_setup_skill = lambda: False
+
+    project_root = tmp_path / "steve-thought-capture"
+    (project_root / "src").mkdir(parents=True)
+    monkeypatch.setenv("HERMES_STEVE_THOUGHT_CAPTURE_ROOT", str(project_root))
+
+    source = SessionSource(
+        platform=Platform.TELEGRAM,
+        chat_id="123",
+        chat_type="dm",
+        user_id="steve",
+        user_name="Steve",
+    )
+    event = MessageEvent(
+        text="",
+        message_type=MessageType.VOICE,
+        source=source,
+        media_urls=["/tmp/queued-voice.ogg"],
+        media_types=["audio/ogg"],
+    )
+
+    pipeline_result = {
+        "status": "ok",
+        "normalized_transcript": {
+            "normalized_text": "麥克風測試 我最喜歡的model是anthropic opus",
+        },
+        "intent_decision": {
+            "primary_intent": "conversation_reply",
+        },
+        "actions": [
+            {"action_type": "reply"},
+        ],
+    }
+
+    with patch(
+        "gateway.run.execute_steve_thought_capture_pipeline",
+        return_value=pipeline_result,
+    ), patch(
+        "tools.transcription_tools.transcribe_audio",
+        side_effect=AssertionError("generic STT should not be called when Steve voice pipeline is enabled"),
+    ):
+        result = await runner._prepare_inbound_message_text(
+            event=event,
+            source=source,
+            history=[],
+        )
+
+    assert result is not None
+    assert "麥克風測試" in result
+    assert "conversation_reply" in result
+    assert "reply" in result
-- 
